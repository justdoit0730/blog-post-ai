<main class="th-layout-main">
    <div class="th-layout-content">
        <section class="butti-N10" id="Rymf138FGh" style="height: 8.2rem;">
        </section>
        <div class="basic-N50" id="AKMF137D57">
            <div class="contents-container container-md">
                <div class="contents-inner">
                    <div class="textset">
                        <h2 class="h2 textset-tit">Profile</h2>
                        <button class="contents-btn btn-filter" type="button">
                            <img src="/resources/icons/ico_filter_black.svg" alt="모바일 필터 아이콘" />
                        </button>
                    </div>
                    <div class="contents-body">
                        <div class="contents-left">
                            <div class="contents-filter-header">
                                <strong class="p1">필터</strong>
                                <button class="contents-btn btn-close">
                                    <img src="/resources/icons/ico_close_black.svg" alt="닫기 아이콘" />
                                </button>
                            </div>
                            <div class="contents-filter-body">
                                <div class="accordset accordset-plus">
                                    <div class="accordset-item">
                                        <div class="accordset-header">
                                            <button class="accordset-button btn" type="button">
                                                <span class="p1" style="cursor:pointer;" onclick="location.href='/myPage/profile'">회원 정보</span>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="accordset-item">
                                        <div class="accordset-header-content">
                                            <button class="accordset-button btn" type="button">
                                                <span class="p1">AI 설정</span>
                                            </button>
                                        </div>
                                        <div class="accordset-body">
                                            <div class="accordset-content">
                                                <div class="form-box" style="margin-bottom: 1.5rem;">
                                                    <div class="checkset-fill-round">
                                                        <label for="" class="checkset-label" style="cursor: pointer;" onclick="location.href='/myPage/ai/setting'">AI Token 및 설정</label>
                                                    </div>
                                                </div>
                                                <div class="form-box" style="margin-bottom: 1.5rem;">
                                                    <div class="checkset-fill-round">
                                                        <label for="" class="checkset-label" style="cursor: pointer;" onclick="location.href='/myPage/ai/template/setting'">AI 글쓰기 Template</label>
                                                    </div>
                                                </div>
                                                <div class="form-box" style="margin-bottom: 1rem;">
                                                    <div class="checkset-fill-round">
                                                        <label for="" class="checkset-label" style="cursor: pointer;" onclick="location.href='/feature/write/list'">AI 글쓰기 목록</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="accordset-item">
                                        <div class="accordset-header-content">
                                            <button class="accordset-button btn" type="button">
                                                <span class="p1">Naver Cafe 설정</span>
                                            </button>
                                        </div>
                                        <div class="accordset-body">
                                            <div class="accordset-content">

                                                <div class="form-box" style="margin-bottom: 1.5rem;">
                                                    <div class="checkset-fill-round">
                                                        <label for="basic-N50-checkset-d-1" class="checkset-label" style="cursor: pointer;" onclick="location.href='/myPage/postingSetting'">API Client 설정</label>
                                                    </div>
                                                </div>

                                                <div class="form-box" style="margin-bottom: 1.5rem;">
                                                    <div class="checkset-fill-round">
                                                        <label for="basic-N50-checkset-d-1" class="checkset-label" style="cursor: pointer;" onclick="location.href='/myPage/postingTemplate'">Cafe 포스팅 Template</label>
                                                    </div>
                                                </div>

                                                <div class="form-box" style="margin-bottom: 1.5rem;">
                                                    <div class="checkset-fill-round">
                                                        <label for="basic-N50-checkset-d-2" class="checkset-label" style="cursor: pointer;" onclick="location.href='/myPage/scheduleSetting'">예약 포스팅 템플릿 설정</label>
                                                    </div>
                                                </div>
                                                <div class="form-box">
                                                    <div class="checkset-fill-round">
                                                        <label for="basic-N50-checkset-d-2" class="checkset-label" style="cursor: pointer;" onclick="location.href='/myPage/scheduleSetting'">포스팅 목록</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!--관리자-->
                                    {{#isManager}}
                                        <div class="accordset-item">
                                            <div class="accordset-header-content">
                                                <button class="accordset-button btn" type="button">
                                                    <span class="p1">관리자 설정</span>
                                                </button>
                                            </div>
                                            <div class="accordset-body">
                                                <div class="accordset-content">
                                                    <div class="form-box" style="margin-bottom: 1.5rem;">
                                                        <div class="checkset-fill-round">
                                                            <label for="basic-N50-checkset-d-1" class="checkset-label" style="cursor: pointer;" onclick="location.href='/manager/postingSetting'">API Client 설정</label>
                                                        </div>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                    {{/isManager}}
                                    <!--관리자-->

                                    <div class="accordset-item">
                                        <div class="accordset-header">
                                            <button class="accordset-button btn" type="button">
                                                <span class="p1">혜택</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>