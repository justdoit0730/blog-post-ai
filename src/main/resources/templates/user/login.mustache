                                    </div>
                                </div>
                            </div>
                            <div class="form-box" style="display: none;">
                                <div class="inputset" style="margin-top: 3rem;">
                                    <label for="" class="form-tit h6" style="margin-bottom: 2rem;">Client 정보</label>
                                    <div style="display: flex;gap: 8px;align-items: center;">
                                        <div style="width: 40%">
                                            <label for="signUpClientId" class="checkset-label" style="margin-bottom: 1rem;">Client ID</label>
                                            <input type="text" id="signUpClientId" class="inputset-input form-control" value="dmvYuC3cmUwzG_KtXtgh" placeholder="Client ID 를 입력해주세요"/>
                                        </div>
                                        <div style="width: 40%">
                                            <label for="signUpClientSecret" class="checkset-label" style="margin-bottom: 1rem;">Client Secret</label>
                                            <input type="password" id="signUpClientSecret" class="inputset-input form-control" value="lGVLRAUMrb" placeholder="Client Secret 입력해주세요"/>
                                        </div>
                                        <div style="width: 20%;">
                                            <label for="" class="checkset-label" style="margin-bottom: 1rem;"></label>
                                            <button type="button" id="naverLoginBtn" class="btnset btnset-primary btnset-block">Client 확인</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="contents-agree" style="margin-top: 6rem">
                                <div class="checkset checkset-fill">
                                    <input id="isPrivacyAgreed" name="개인정보 수집동의" class="checkset-input" type="checkbox" value="개인정보 수집동의" />
