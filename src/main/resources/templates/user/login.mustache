                                <h2 class="h2 textset-tit">회원가입</h2>
                            </div>
                            <div class="form-box">
                                <div class="inputset">
                                    <label for="signUpLogin" class="form-tit h6" style="margin-bottom: 2rem;">이메일</label>
                                    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 4rem;">
