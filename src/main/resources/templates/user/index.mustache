{{>layout/header}}
<meta name="_csrf" content="{{_csrf_token}}"/>
<meta name="_csrf_header" content="{{_csrf_header}}"/>

<main class="th-layout-main">
    <div class="th-layout-content">

        <section class="butti-N4" id="SxmF2HP8tZ">
            <h2 class="blind">AUTO CAFE 메인 비주얼</h2>

            <div class="contents-container container-md fullscreen">
                <div class="slide-area">
                    <div class="swiper">
                        <div class="swiper-wrapper">

                            <!-- 슬라이드 1 -->
                            <div class="swiper-slide">
                                <picture>
                                    <source media="(max-width:992px)" srcset="./resources/profile/mainBack.jpg" />
                                    <img class="contents-backimg img-pc" src="./resources/profile/mainBack.jpg" alt="AI 글쓰기 서비스 소개" />
                                </picture>
                                <div style="position: absolute; top: 0; left: 0; width: 80%; height: 100%; background: linear-gradient(to right, rgba(0,0,0,1), rgba(0,0,0,0)); pointer-events: none;"></div>
                                <div class="contents-slide-group">
                                    <strong class="textset-tit h1">AI가 대신 글을 작성합니다.</strong>
                                    <p class="textset-desc p2">
                                        주제와 프롬프트만 입력하면 AI가 자연스러운 글을 자동 생성합니다.<br />
                                        클릭 한 번으로 원하는 글을 완성해보세요.
                                    </p>
                                    <a class="btnset btnset-line-white" href="/feature/write">AI 글쓰기 시작하기</a>
                                </div>
                            </div>

                            <!-- 슬라이드 2 -->
                            <div class="swiper-slide">
                                <picture>
                                    <source media="(max-width:992px)" srcset="./resources/profile/wallpaper_2.jpg" />
                                    <img class="contents-backimg img-pc" src="./resources/profile/wallpaper_main_2.jpg" alt="Naver Cafe 포스팅 소개" />
                                </picture>

                                <div class="contents-slide-group">
                                    <div class="textset textset-visual">
                                        <strong class="textset-tit h1">네이버 카페에 자동으로 포스팅.</strong>
                                        <p class="textset-desc p2">
                                            카페 ID와 게시판 정보만 입력하면<br />
                                            작성한 글을 AI가 자동으로 게시해드립니다.
                                        </p>
                                    </div>
                                    <a class="btnset btnset-line-white" href="/cafe/post">카페 포스팅하기</a>
                                </div>
                            </div>

                            <!-- 슬라이드 3 -->
                            <div class="swiper-slide">
                                <picture>
                                    <source media="(max-width:992px)" srcset="./resources/profile/wallpaper_3.jpg" />
                                    <img class="contents-backimg img-pc" src="./resources/profile/wallpaper_3.jpg" alt="AI 자동 포스팅 소개" />
                                </picture>

                                <div class="contents-slide-group">
                                    <div class="textset textset-visual">
                                        <strong class="textset-tit h1">AI가 글 생성부터 게시까지 한 번에.</strong>
                                        <p class="textset-desc p2">
                                            주제만 입력하면 AI가 글을 생성하고,<br />
                                            즉시 네이버 카페에 포스팅합니다.
                                        </p>
                                    </div>
                                    <a class="btnset btnset-line-white" href="/cafe/ai/post">AI 자동 포스팅</a>
                                </div>
                            </div>

                        </div>

                        <div class="swiper-button-next"></div>
                        <div class="swiper-button-prev"></div>

                        <div class="contents-control">
                            <div class="swiper-pagination"></div>
                            <div class="swiper-button-pause">
                                <img src="./resources/icons/ico_pause_white.svg" alt="스와이퍼 멈춤버튼" />
                            </div>
                            <div class="swiper-button-play">
                                <img src="./resources/icons/ico_play_white.svg" alt="스와이퍼 재생버튼" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 기능 소개 섹션 -->
        <section class="butti-N5" id="featureSection">
            <h2 class="blind">AUTO CAFE 기능 소개</h2>

            <div class="contents-container container-md">
                <div class="contents-inner">

                    <!-- AI 글쓰기 -->
                    <div class="item">
                        <div class="thumb">
                            <img class="cardset-img" src="./resources/index/index-ai.jpg" alt="AI 글쓰기 이미지" />
                        </div>
                        <div class="desc">
                            <strong class="cardset-tit h3">AI 글쓰기</strong>
                            <p class="cardset-desc p1">
                                GPT 기반 모델을 통해 자연스럽고 품질 높은 글을 자동 생성합니다.<br />
                                max_tokens, temperature 등 다양한 설정을 지원합니다.
                            </p>
                            <a class="btnset btnset-line-dark btnset-lg" href="/feature/write">사용해보기</a>
                        </div>
                    </div>

                    <!-- 카페 포스팅 -->
                    <div class="item reverse">
                        <div class="thumb">
                            <img class="cardset-img" src="./resources/index/ChatGPT_naver_cafe.png" alt="카페 포스팅 이미지" />
                        </div>
                        <div class="desc">
                            <strong class="cardset-tit h3">Naver Cafe 포스팅</strong>
                            <p class="cardset-desc p1">
                                카페 ID, 게시판 ID, 제목, 내용을 입력하면<br />
                                네이버 카페에 직접 글을 게시할 수 있습니다.
                            </p>
                            <a class="btnset btnset-line-dark btnset-lg" href="/cafe/post">포스팅하기</a>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- AI 자동 포스팅 강조 섹션 -->
        <section class="butti-N8" id="autoPostingBanner">
            <div class="contents-container container-md">
                <div class="title-area">
                    <h2 class="h3">AI로 자동 포스팅을 경험해보세요.</h2>
                    <p class="p1">
                        글 생성부터 게시까지 한 번에 처리되는 AI 자동 포스팅 기능을 제공합니다.
                    </p>
                    <a class="btnset btnset-line-white btnset-lg" href="/cafe/ai/post">AI 자동 포스팅 시작</a>
                </div>
            </div>
        </section>

        <!-- 하단 카드 슬라이드 (홍보용) -->
        <section class="butti-N7" id="ciMF2HP8ZJ">
            <div class="contents-container container-md">

                <div class="contents-inner">
                    <div class="textset">
                        <h2 class="textset-tit h3">AUTO CAFE 주요 기능</h2>
                        <p class="textset-desc p1">더 편리한 카페 운영을 위한 기능들을 제공합니다.</p>
                    </div>

                    <div class="contents-swiper">
                        <div class="swiper-wrapper">

                            <!-- 반복 카드 -->
                            <div class="swiper-slide">
                                <div class="contents-slide-group">
                                    <a class="cardset">
                                        <figure class="cardset-figure">
                                            <img class="cardset-img" src="./resources/index/1.jpg" alt="AI 글 생성" />
                                        </figure>
                                        <div class="cardset-body">
                                            <strong class="cardset-tit p1">AI 글 생성</strong>
                                            <p class="cardset-desc p2">프롬프트만 입력하면 AI가 글을 직접 작성합니다.</p>
                                        </div>
                                    </a>
                                </div>
                            </div>

                            <div class="swiper-slide">
                                <div class="contents-slide-group">
                                    <a class="cardset">
                                        <figure class="cardset-figure">
                                            <img class="cardset-img" src="./resources/index/2.jpg" alt="카페 포스팅" />
                                        </figure>
                                        <div class="cardset-body">
                                            <strong class="cardset-tit p1">카페 포스팅</strong>
                                            <p class="cardset-desc p2">글을 작성하여 네이버 카페에 게시할 수 있습니다.</p>
                                        </div>
                                    </a>
                                </div>
                            </div>

                            <div class="swiper-slide">
                                <div class="contents-slide-group">
                                    <a class="cardset">
                                        <figure class="cardset-figure">
                                            <img class="cardset-img" src="./resources/index/3.png" alt="AI 자동 포스팅" />
                                        </figure>
                                        <div class="cardset-body">
                                            <strong class="cardset-tit p1">AI 자동 포스팅</strong>
                                            <p class="cardset-desc p2">AI가 생성과 게시를 모두 자동으로 수행합니다.</p>
                                        </div>
                                    </a>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="contents-slide-group">
                                    <a class="cardset">
                                        <figure class="cardset-figure">
                                            <img class="cardset-img" src="./resources/index/4.png" alt="프로필 & 가이드" />
                                        </figure>
                                        <div class="cardset-body">
                                            <strong class="cardset-tit p1">프로필 및 가이드</strong>
                                            <p class="cardset-desc p2">
                                                쉽게 프로필 설정과 확인을 할 수 있고,<br />
                                                문의, 사용 가이드도 함께 제공합니다.
                                            </p>
                                        </div>
                                    </a>
                                </div>
                            </div>

                        </div>

                        <div class="swiper-button-next"></div>
                        <div class="swiper-button-prev"></div>
                    </div>

                    <div class="contents-control">
                        <div class="swiper-pagination"></div>
                    </div>

                </div>
            </div>
        </section>

    </div>
</main>



{{>layout/footer}}