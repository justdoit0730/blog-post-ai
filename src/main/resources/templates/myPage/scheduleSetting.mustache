<style>
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
    }
    th, td {
      border: 1px solid #ccc;
      padding: 6px;
      text-align: center;
    }
    th {
      background: #f8f8f8;
    }
    .small-col {
      width: 60px;
    }
    .inactive {
      opacity: 0.4;
    }
    .delete-btn {
      background: red;
      color: white;
      border: none;
      padding: 2px 6px;
      cursor: pointer;
    }
    /* 요일 드롭다운 */
    .day-dropdown {
      position: relative;
      display: inline-block;
    }
    .dropdown-toggle {
      padding: 4px 8px;
      cursor: pointer;
      border: 1px solid #aaa;
      background: #f9f9f9;
    }
    .dropdown-menu {
      display: none;
      position: absolute;
      background: #fff;
      border: 1px solid #ddd;
      padding: 8px;
      z-index: 100;
    }
    .dropdown-menu label {
      display: block;
    }
  </style>
              <div class="contents-right">
                <div class="row row-cols-3 row-md-cols-2 gutter-5 contents-list" style="margin-top: 0rem; margin-bottom: 0em; --th-gutter: 0;">
                    <div class="contents-container container-md">
                        <div class="contents-inner" style="width: 100%; padding: 5rem 4rem; border-radius: 2rem; background: #f7f7fb;">
                            <div class="form-group">
                                <form>
                                    <div class="textset">
                                        <h2 class="h2 textset-tit">API Client 설정</h2>
                                    </div>
                                    <div class="form-box" style="margin-bottom: 1rem;">
                                        <div class="inputset">
                                            <label for="signUpLogin" class="form-tit h6" style="margin-bottom: 1rem;">AI 글 게시 설정</label>
                                            <button id="addRowBtn" class="add-btn" type="button">행 추가</button>
                                            <div style="display: flex; gap: 8px; align-items: center;">
<!--                                                여기-->




                                                <table id="dynamicTable">
                                                    <thead>
                                                    <tr>
                                                        <th class="small-col">사용 여부</th>
                                                        <th class="small-col">No</th>
                                                        <th class="small-col">카페 게시판 id</th>
                                                        <th>게시판 이름</th>
                                                        <th>주제</th>
                                                        <th>요일</th>
                                                        <th>시간</th>
                                                        <th class="small-col">삭제</th>
                                                    </tr>
                                                    </thead>
                                                    <tbody>
                                                    </tbody>
                                                </table>

                                                <script>
  const tableBody = document.querySelector("#dynamicTable tbody");
  const addRowBtn = document.getElementById("addRowBtn");

  // ✅ 번호 갱신
  function updateRowNumbers() {
    [...tableBody.rows].forEach((row, index) => {
      row.cells[1].textContent = index + 1;
    });
  }

  // ✅ 행 추가
  addRowBtn.addEventListener("click", () => {
    const row = tableBody.insertRow();

    // 사용 여부
    const useCell = row.insertCell(0);
    const checkbox = document.createElement("input");
    checkbox.type = "checkbox";
    checkbox.checked = true;
    checkbox.addEventListener("change", () => {
      row.classList.toggle("inactive", !checkbox.checked);
    });
    useCell.appendChild(checkbox);

    // No
    const noCell = row.insertCell(1);
    noCell.textContent = tableBody.rows.length;

    // 카페 게시판 id
    const idCell = row.insertCell(2);
    const idInput = document.createElement("input");
    idInput.type = "text";
    idCell.appendChild(idInput);

    // 게시판 이름
    const nameCell = row.insertCell(3);
    const nameInput = document.createElement("input");
    nameInput.type = "text";
    nameCell.appendChild(nameInput);

    // 주제
    const subjectCell = row.insertCell(4);
    const subjectInput = document.createElement("input");
    subjectInput.type = "text";
    subjectCell.appendChild(subjectInput);

    // 요일 (드롭다운 체크박스)
    const dayCell = row.insertCell(5);
    const dayDropdown = document.createElement("div");
    dayDropdown.className = "day-dropdown";
    const toggleBtn = document.createElement("button");
    toggleBtn.type = "button";
    toggleBtn.textContent = "요일 선택 ▼";
    toggleBtn.className = "dropdown-toggle";
    const menu = document.createElement("div");
    menu.className = "dropdown-menu";
    ["월", "화", "수", "목", "금", "토", "일"].forEach(day => {
      const label = document.createElement("label");
      const cb = document.createElement("input");
      cb.type = "checkbox";
      cb.value = day;
      label.appendChild(cb);
      label.appendChild(document.createTextNode(day));
      menu.appendChild(label);
    });
    toggleBtn.addEventListener("click", () => {
      menu.style.display = menu.style.display === "block" ? "none" : "block";
    });
    dayDropdown.appendChild(toggleBtn);
    dayDropdown.appendChild(menu);
    dayCell.appendChild(dayDropdown);

    // 시간 (초단위 입력)
    const timeCell = row.insertCell(6);
    const timeInput = document.createElement("input");
    timeInput.type = "time";
    timeInput.step = "1"; // 초 단위
    const now = new Date();
    timeInput.min = now.toISOString().slice(11,19); // 현재 이후
    timeCell.appendChild(timeInput);

    // 삭제
    const deleteCell = row.insertCell(7);
    const deleteBtn = document.createElement("button");
    deleteBtn.textContent = "X";
    deleteBtn.className = "delete-btn";
    deleteBtn.type = "button";
    deleteBtn.addEventListener("click", () => {
      row.remove();
      updateRowNumbers();
    });
    deleteCell.appendChild(deleteBtn);
  });
</script>
<!--                                                여기-->

                                            </div>
                                        </div>
                                    </div>

