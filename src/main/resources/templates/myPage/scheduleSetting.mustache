{{>layout/mypageSidebar}}
<meta name="_csrf" content="{{_csrf_token}}"/>
<meta name="_csrf_header" content="{{_csrf_header}}"/>
<style>
#tableIdDiv {
  background: white;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  overflow-x: auto;
  display: flex;
  gap: 8px;
  align-items: center;
}

#tableDiv {
  background: white;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  overflow-x: auto;
  display: flex;
  gap: 8px;
  align-items: center;
}

.tableset-table {
  width: 100%;
  table-layout: fixed;
  border-collapse: collapse;
}

.tableset-table th,
.tableset-table td {
  border: 1px solid #ccc;
  overflow: hidden;
  white-space: nowrap;
  text-align: center;
  padding: 6px;
}

.tableset-table thead tr {
  border-bottom: 3px solid #666;
}

.tableset-table thead th {
  background-color: #f7f7fb;
  border-bottom: 3px solid #666;
  text-align: center;
  padding: 6px;
  overflow: hidden;
  white-space: nowrap;

  font-size: 16px;
  font-weight: 600;
}

.tableset-table td:first-child,
.tableset-table th:first-child {
  border-left: none;
}

.tableset-table td:last-child,
.tableset-table th:last-child {
  border-right: none;
}

.inactive {
  opacity: 0.4;
}
.delete-btn {
  background: red;
  color: white;
  border: none;
  padding: 2px 6px;
  cursor: pointer;
}
/* 요일 드롭다운 */
.day-dropdown {
  position: relative;
  display: inline-block;
}
.dropdown-toggle {
  cursor: pointer;
  background: #fff;
}
.dropdown-menu {
  display: none;
  position: absolute;
  background: #fff;
  border: 1px solid #ddd;
  padding: 8px;
  z-index: 100;
}
.dropdown-menu label {
  display: flex;
  align-items: center;
  gap: 6px;              /* 체크박스 오른쪽 여백 */
  font-size: 14px;
  cursor: pointer;
  padding: 2px 4px;
}

.dropdown-menu label:hover {
  background-color: #f3f3f3;
  border-radius: 4px;
}
</style>
<div class="contents-right">
    <div class="row row-cols-3 row-md-cols-2 gutter-5 contents-list" style="margin-top: 0rem; margin-bottom: 0em; --th-gutter: 0;">
        <div class="contents-container container-md">
            <div class="contents-inner">
                <div class="form-group">

                    <form>
                        <div class="textset" style="margin-bottom: 0rem;">
                            <h2 class="h2 textset-tit">예약 포스팅 Template</h2>
                        </div>
                        <div class="form-box" style="margin-bottom: 4rem;">
                            <div class="inputset">
                                <div class="form-btn" style="margin-bottom: 2rem; text-align: right;">
                                    <button class="btnset btnset-primary btnset-block" type="button" id="addIdRowBtn" style="width: 10%;">추가</button>
                                </div>
                                <div id="tableIdDiv" style="display: block; overflow-x: auto; align-items: center;" data-template='cafeIdTemplate}}}'>
                                    <table class="tableset-table table" id="dynamicIdTable" style="min-width: 800px;">

                                        <colgroup>
                                            <col style="width: 5%;" />   <!-- 사용 여부 -->
                                            <col style="width: 5%;" />   <!-- No -->
                                            <col style="width: 10%;" />  <!-- 태그 -->
                                            <col style="width: 10%;" />  <!-- 카페 ID -->
                                            <col style="width: 10%;" />  <!-- 카페 게시판 ID -->
                                            <col style="width: 15%;" />   <!-- 주제 -->
                                            <col style="width: 30%;" />   <!-- 요청 사항 -->
                                            <col style="width: 7%;" />   <!-- 요일 -->
                                            <col style="width: 14%;" />   <!-- 시간 -->
                                            <col style="width: 5%;" />   <!-- 삭제 -->
                                        </colgroup>
                                        <thead class="thead-light thead-border-top">
                                        <tr>
                                            <th scope="col" class="p2" style="background-color: black; color: white;">사용</th>
                                            <th scope="col" class="p2" style="background-color: black; color: white;">No</th>
                                            <th scope="col" class="p2" style="background-color: black; color: white;">태그</th>
                                            <th scope="col" class="p2" style="background-color: black; color: white;">카페 ID</th>
                                            <th scope="col" class="p2" style="background-color: black; color: white;">게시판 ID</th>
                                            <th scope="col" class="p2" style="background-color: black; color: white;">주제</th>
                                            <th scope="col" class="p2" style="background-color: black; color: white;">요청 사항</th>
                                            <th scope="col" class="p2" style="background-color: black; color: white;">요일</th>
                                            <th scope="col" class="p2" style="background-color: black; color: white;">시간</th>
                                            <th scope="col" class="p2" style="background-color: black; color: white;">삭제</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="form-btn" style="text-align: right; margin-bottom: 3rem;">
                            <button class="btnset btnset-primary" type="button" id="cafeIdTemplateSave">저장하기</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
</div>
</div>
<div class="contents-dim"></div>
</div>

</div>
</main>


<script>
  const tableIdBody = document.querySelector("#dynamicIdTable tbody");
  const addIdRowBtn = document.getElementById("addIdRowBtn");

  function updateIdRowNumbers() {
    [...tableIdBody.rows].forEach((row, index) => {
      row.cells[1].textContent = index + 1;
    });
  }

  addIdRowBtn.addEventListener("click", () => {
    const row = tableIdBody.insertRow();

    // 사용 여부
    const useCell = row.insertCell(0);
    const checkbox = document.createElement("input");
    checkbox.type = "checkbox";
    checkbox.checked = true;
    checkbox.addEventListener("change", () => {
      row.classList.toggle("inactive", !checkbox.checked);
    });
    useCell.appendChild(checkbox);

    // No
    const noCell = row.insertCell(1);
    noCell.textContent = tableIdBody.rows.length;

    // 태그
    createEditableCell(row, "");

    // 카페 ID
    createEditableCell(row, "");

    // 카페 게시판 ID
    createEditableCell(row, "");

    // 주제
    createEditableCell(row, "");

    // 요청 사항
    createEditableCell(row, "");

    // 요일 드롭다운
    const dayCell = row.insertCell(7);
    const dayDropdown = document.createElement("div");
    dayDropdown.className = "day-dropdown";

    const toggleBtn = document.createElement("button");
    toggleBtn.type = "button";
    toggleBtn.textContent = "선택 ▼";
    toggleBtn.className = "dropdown-toggle";

    const menu = document.createElement("div");
    menu.className = "dropdown-menu";

    ["월", "화", "수", "목", "금", "토", "일"].forEach(day => {
      const label = document.createElement("label");
      const cb = document.createElement("input");
      cb.type = "checkbox";
      cb.value = day;
      label.appendChild(cb);
      label.appendChild(document.createTextNode(day));
      menu.appendChild(label);
    });

    toggleBtn.addEventListener("click", (e) => {
      e.stopPropagation();

      document.querySelectorAll(".dropdown-menu").forEach(m => (m.style.display = "none"));

      if (menu.style.display === "block") {
        menu.style.display = "none";
      } else {
        const rect = toggleBtn.getBoundingClientRect();
        document.body.appendChild(menu); // body로 옮겨 테이블 위로 표시
        menu.style.position = "absolute";
        menu.style.left = `${rect.left + window.scrollX}px`;
        menu.style.top = `${rect.bottom + window.scrollY}px`;
        menu.style.display = "block";
      }
    });

    document.addEventListener("click", (e) => {
      // 드롭다운 내부나 토글 버튼 클릭이면 무시
      if (e.target.closest(".dropdown-menu") || e.target.classList.contains("dropdown-toggle")) return;
      document.querySelectorAll(".dropdown-menu").forEach(m => (m.style.display = "none"));
    });

    dayDropdown.appendChild(toggleBtn);
    dayDropdown.appendChild(menu);
    dayCell.appendChild(dayDropdown);

    // 시간 입력 (초단위 가능)
    const timeCell = row.insertCell(8);
    const timeInput = document.createElement("input");
    timeInput.type = "time";
    timeInput.step = "1";
    timeCell.appendChild(timeInput);

    // 삭제 버튼
    const deleteCell = row.insertCell();
    const deleteBtn = document.createElement("button");
    deleteBtn.className = "delete-btn";
    deleteBtn.type = "button";
    deleteBtn.style.background = "white";

    const img = document.createElement("img");
    img.src = "/resources/profile/delete.svg";
    img.alt = "삭제";
    img.style.width = "2rem";
    img.style.objectFit = "contain";

    deleteBtn.appendChild(img);



    deleteBtn.addEventListener("click", () => {
      row.remove();
      updateIdRowNumbers();
    });
    deleteCell.appendChild(deleteBtn);
  });
</script>

<script src="/js/myPage/cafeTemplateSave.js"></script>
