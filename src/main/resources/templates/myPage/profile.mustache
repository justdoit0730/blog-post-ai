{{>layout/header}}
    {{>layout/profileSidebar}}
        <meta name="_csrf" content="{{_csrf_token}}"/>
        <meta name="_csrf_header" content="{{_csrf_header}}"/>

                        <div class="contents-right">
                            <div class="row row-cols-3 row-md-cols-2 gutter-5 contents-list" style="margin-top: 0rem; margin-bottom: 0em; --th-gutter: 0;">
                                <div class="contents-container container-md">
                                    <div class="contents-inner">
                                        <div class="form-group">
                                            <form>
                                                <div class="textset">
                                                    <h2 class="h2 textset-tit">회원 정보</h2>
                                                </div>
                                                <div class="form-box" style="margin-bottom: 4rem;">
                                                    <div class="inputset">
                                                        <label class="form-tit h6" style="margin-bottom: 1rem; display: flex; gap: 8px; align-items: center;">
                                                            <label class="form-tit h6" style="display: flex; gap: 2rem; align-items: center;">
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="radio" name="flexRadioDefault" id="emailUseCheck" {{^isSubEmailUsed}}checked{{/isSubEmailUsed}}>
                                                                    <label class="form-check-label" for="emailUseCheck">
                                                                        이메일
                                                                    </label>
                                                                </div>
                                                                </label>
                                                            <div>
                                                                <img src="/resources/profile/black-circle-question-regular-full.svg" alt="N" style="height: 2.5rem; cursor: pointer;" data-bs-toggle="tooltip" data-bs-placement="right"
                                                                     title="로그인에 사용되는 이메일은 변경이 불가능합니다. AUTO CAFE 정보 수신용 이메일 주소는 추가 및 변경할 수 있습니다." />
                                                            </div>
                                                        </label>
                                                        <div style="display: flex; gap: 8px; align-items: center;">
                                                            <input id="email" type="text" class="inputset-input form-control" value="{{email}}" disabled />
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="form-box" style="margin-bottom: 4rem;">
                                                    <div class="inputset">
                                                        <label for="signUpLogin" class="form-tit h6" style="margin-bottom: 1rem; display: flex; gap: 2rem; align-items: center;">
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="radio" name="flexRadioDefault" id="subEmailUseCheck" {{#isSubEmailUsed}}checked{{/isSubEmailUsed}}>
                                                                <label class="form-check-label" for="subEmailUseCheck">
                                                                    추가 이메일
                                                                </label>
                                                            </div>
                                                            </label>
                                                        <div style="display: flex; gap: 8px; align-items: center;">
                                                            <input id="subEmail" type="text" class="inputset-input form-control" placeholder="이메일을 입력해 주세요." value="{{subEmail}}" {{#subEmailExists}} disabled {{/subEmailExists}}/>
                                                            <button class="btnset btnset-primary btnset-block" type="button" id="sendAuthBtn" style="width: 30%; margin-top: 0; margin-left: 0;" {{#subEmailExists}} disabled {{/subEmailExists}}>인증문자 전송</button>
                                                            <button class="btnset btnset-primary btnset-block" type="button" id="rewriteEmailBtn" style="width: 30%; margin-top: 0; margin-left: 0;">이메일 초기화</button>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="form-box" style="margin-bottom: 5rem;">
                                                    <div class="inputset">
                                                        <label for="signUpAuthCode" class="form-tit h6" style="margin-bottom: 1rem;">추가 이메일 인증</label>  <span id="countdown"></span>
                                                        <div style="display: flex; gap: 8px; align-items: center;">
                                                            <input id="signUpAuthCode" type="password" class="inputset-input form-control" placeholder="이메일에 전송된 인증문자를 입력해 주세요." {{#subEmailExists}} disabled {{/subEmailExists}}/>
                                                            <button class="btnset btnset-primary btnset-block" type="button" id="verifyAuthBtn" style="width: 30%; margin-top: 0; margin-left: 0;" {{#subEmailExists}} disabled {{/subEmailExists}}>인증문자 확인</button>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="form-btn" style="margin-bottom: 8rem;">
                                                    <button class="btnset btnset-primary btnset-block" type="button" id="subEmailSave" >저장</button>
                                                </div>
                                                <div class="form-box" style="margin-bottom: 5rem;">
                                                    <div class="inputset">
                                                        <label for="signUpAuthPassword" class="form-tit h6" style="margin-bottom: 1rem;">비밀번호 변경</label>
                                                        <div style="display: flex; gap: 8px; align-items: center;">
                                                            <input id="signUpAuthPassword" type="password" class="inputset-input form-control" placeholder="비밀번호를 입력해 주세요." />
                                                            <input id="signUpAuthPasswordCheck" type="password" class="inputset-input form-control" placeholder="비밀번호를 한번 더 입력해 주세요." />
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <div id="pwFeedback" style="margin-top: 2rem; margin-bottom: 1.5rem;"></div>
                                                        <div id="pwStrength" style="height:10px; width:100%; background:#eee; margin-top:5px;">
                                                            <div id="pwStrengthBar" style="height:100%; width:0%; background:red;"></div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="form-btn" style="margin-bottom: 8rem;">
                                                    <button class="btnset btnset-primary  btnset-block" type="button" id="passwordUpdate">비밀번호 변경</button>
                                                </div>
                                                <div class="form-box" style="margin-bottom: 5rem;">
                                                    <div class="inputset">
                                                        <label for="signUpAuthPassword" class="form-tit h6" style="margin-bottom: 1rem;">회원 탈퇴</label>
                                                    </div>
                                                </div>
                                                <div class="form-btn" style="margin-bottom: 8rem;">
                                                    <button class="btnset btnset-red btnset-block modalset-open-btn modal-privacy-btn" type="button" data-modal-target="modalset-user-delete">탈퇴하기</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <div class="basic-N24" style="padding: 0">
                                    <div class="modalset modalset-md" data-modal-id="modalset-user-delete">
                                        <div class="modalset-content">
                                            <div class="modalset-header">
                                                <h2 class="h5 modalset-title">회원 탈퇴</h2>
                                                <button class="modalset-close" data-modal-close="modalset"></button>
                                            </div>

                                            <div class="modalset-body">
                                                <div class="modalset-textarea">
                                                    <div class="info-area" style="height: 38rem;">
                                                        <div class="info-group">
                                                            <strong class="h6">회원 정보 삭제 안내</strong>
                                                            <div class="info-desc">
                                                                <p>회원 정보를 삭제합니다. 게시글을 포함한 모든 정보가 영구적으로 삭제되며, 삭제 완료 후에는 복구가 불가능합니다.</p>
                                                                <p>회원 정보를 삭제하려면 아래에 표시된 코드를 정확히 입력해주세요.</p>
                                                            </div>
                                                        </div>

                                                        <div class="code-area" style="margin-top: 1.5rem;">
                                                            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                                                                <input id="deleteCodeDisplay" type="text" class="inputset-input form-control" disabled style="text-align: center;">
                                                                <input id="deleteCodeInput" type="text" class="inputset-input form-control" placeholder="위 코드를 정확히 입력하세요" style="text-align:center;">
                                                            </div>
                                                            <div style="display: flex; flex-direction: column; gap: 0.75rem; margin: 2rem 0 1rem 0;">
                                                                <p>비밀번호</p>
                                                                <input id="deletePasswordInput" type="password" class="inputset-input form-control" placeholder="비밀번호를 정확히 입력하세요" style="text-align:center;">
                                                            </div>
                                                        </div>

                                                        <div class="contents-agree" style="margin-top: 2.5rem;">
                                                            <div class="checkset checkset-fill">
                                                                <input id="agreeDeleteAccount" name="회원정보삭제동의" class="checkset-input" type="checkbox" value="동의">
                                                                <label for="agreeDeleteAccount" class="checkset-label">회원 정보를 삭제하는 것에 동의합니다.</label>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="modalset-footer">
                                                <button id="confirmDeleteBtn" class="btnset btnset-primary">삭제</button>
                                                <button class="btnset btnset-line-light" data-modal-close="modalset">취소</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>



                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="contents-dim"></div>
        </div>

    </div>
</main>

<script src="/js/user/subEmail.js"></script>
<script src="/js/user/passwordUpdate.js"></script>
<script src="/js/user/delete.js"></script>

{{>layout/footer}}