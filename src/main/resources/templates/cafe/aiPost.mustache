<script src="/resources/profile/toast/toastui-editor-all.min.js"></script>
<script>
  const editor = new toastui.Editor({
    el: document.querySelector('#editor'),
    height: '500px',
    initialEditType: 'wysiwyg',   // 'markdown' 도 가능
    previewStyle: 'vertical',
    hooks: {
      addImageBlobHook: async (blob, callback) => {
        // blob = 사용자가 올린 이미지 파일

        // 1) 서버에 업로드 하는 경우
        // let formData = new FormData();
        // formData.append("file", blob);
        // const response = await fetch("/upload", { method: "POST", body: formData });
        // const data = await response.json();
        // callback(data.url, "업로드 이미지");

        // 2) 테스트용 (브라우저에만 URL 생성)
        const url = URL.createObjectURL(blob);
        callback(url, "첨부 이미지");
      }
    }
  });

  // 저장할 때 (DB에 넣을 내용)
  function getEditorContent() {
    const html = editor.getHTML();   // HTML
    const markdown = editor.getMarkdown(); // Markdown
    console.log("HTML:", html);
    console.log("MD:", markdown);
  }
</script>
<script>
document.addEventListener("DOMContentLoaded", function() {
    const titleEl = document.getElementById("title");
    const writeSaveDiv = document.getElementById("writeSaveDiv");
    if (titleEl.textContent.trim() !== "") {
        writeSaveDiv.style.display = "block";
    }

    const contentElement = document.getElementById("content");
    let contentHtml = contentElement.textContent;

    const imgUrls = [
        {{#imgUrls}}
            '{{.}}',
        {{/imgUrls}}
    ];

    imgUrls.forEach((imgUrl, index) => {
        const photoTag = `[사진${index + 1}]`;
        const imgHtml = `<br><img src="${imgUrl}" style="max-width:100%;"><br>`;
        contentHtml = contentHtml.replace(photoTag, imgHtml);
    });

    contentHtml = contentHtml.replace(/\r\n/g, "\n").replace(/\n/g, "<br>");

    contentElement.innerHTML = contentHtml;
});
</script>
