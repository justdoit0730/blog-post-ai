                                                    <input id="inquiryEmail" type="email" class="inputset-input form-control" placeholder="이메일을 입력해주세요." required="" />
                                                </div>
                                            </div>

                                            <div class="form-box">
                                                <div class="inputset inputset-line">
                                                    <label for="inquiryTitle" class="form-tit h6">제목 <span>*</span>
